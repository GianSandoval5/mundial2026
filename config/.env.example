FLUPIBASE_BASE_URL=https://flupibase.com/api/v1
FLUPIBASE_PROJECT_ID=mundialito-app
FLUPIBASE_API_KEY=your_flupibase_project_api_key_with_functions_invoke
FLUPIBASE_FUNCTION_NAME=mundialito-football

# Do not put API_FOOTBALL_KEY here.
# Mundial 2026 uses WorldCup26 through Flupibase and does not need that key.
# Historical seasons can use API_FOOTBALL_KEY as a Flupibase Functions secret.
